import streamlit as st
import random

def run():

    st.header("🧠 اختبار الاقتصاد الجزئي")

    questions=[

        ("إذا كانت المرونة أكبر من 1 فالطلب:", "مرن"),

        ("إذا تساوى العرض والطلب نحصل على:", "التوازن")

    ]

    q=random.choice(questions)

    answer=st.radio(q[0],["مرن","غير مرن","التوازن"])

    if st.button("تحقق"):

        if answer==q[1]:

            st.success("صحيح")

        else:

            st.error("خطأ")
